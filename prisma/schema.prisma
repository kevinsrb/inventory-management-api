generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @db.Uuid
  name      String    @unique @db.VarChar(100)
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("categories")
}

model Product {
  id             String              @id @db.Uuid
  sku            String              @unique @db.VarChar(20)
  name           String              @db.VarChar(100)
  categoryId     String              @map("category_id") @db.Uuid
  category       Category            @relation(fields: [categoryId], references: [id])
  price          Decimal             @db.Decimal(12, 2)
  currentStock   Int                 @default(0) @map("current_stock")
  minimumStock   Int                 @map("minimum_stock")
  supplier       String              @db.VarChar(120)
  version        Int                 @default(0)
  movements      InventoryMovement[]
  alerts         StockAlert[]
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([supplier])
  @@index([currentStock])
  @@map("products")
}

model InventoryMovement {
  id        String   @id @db.Uuid
  productId String   @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id])
  type      String   @db.VarChar(10)
  quantity  Int
  reason    String   @db.VarChar(250)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId, createdAt])
  @@map("inventory_movements")
}

model StockAlert {
  id         String          @id @db.Uuid
  productId  String          @map("product_id") @db.Uuid
  product    Product         @relation(fields: [productId], references: [id])
  type       String          @db.VarChar(20)
  status     String          @db.VarChar(12)
  createdAt  DateTime        @default(now()) @map("created_at")
  resolvedAt DateTime?       @map("resolved_at")
  orders     PurchaseOrder[]

  @@index([status])
  @@map("stock_alerts")
}

model PurchaseOrder {
  id              String      @id @db.Uuid
  productId       String      @map("product_id") @db.Uuid
  product         Product     @relation(fields: [productId], references: [id])
  alertId         String?     @map("alert_id") @db.Uuid
  alert           StockAlert? @relation(fields: [alertId], references: [id])
  supplier        String      @db.VarChar(120)
  requestedAmount Int         @map("requested_amount")
  status          String      @db.VarChar(12)
  rejectionReason String?     @map("rejection_reason") @db.VarChar(250)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  receivedAt      DateTime?   @map("received_at")

  @@index([productId])
  @@index([status])
  @@map("purchase_orders")
}
